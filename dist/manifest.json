{
  "manifest_version": 3,
  "name": "X Media Saver",
  "version": "0.2.1",
  "description": "Save media from X (Twitter) posts",
  "permissions": [
    "downloads",
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://cdn.syndication.twimg.com/*",
    "https://pbs.twimg.com/*",
    "https://video.twimg.com/*",
    "https://api.vxtwitter.com/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-DocII-my.js"
      ],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "css": [
        "assets/index-DMqVOBvQ.css"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "https://twitter.com/*",
        "https://x.com/*"
      ],
      "resources": [
        "assets/constants-DEZdbWmU.js",
        "assets/index.ts-BtX6PKat.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
