{
  "manifest_version": 3,
  "name": "Social Media Saver",
  "version": "0.4.0",
  "description": "Save media from X (Twitter) and Reddit posts",
  "permissions": ["downloads", "activeTab", "storage", "notifications"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://cdn.syndication.twimg.com/*",
    "https://pbs.twimg.com/*",
    "https://video.twimg.com/*",
    "https://api.vxtwitter.com/*",
    "https://www.reddit.com/*",
    "https://i.redd.it/*",
    "https://v.redd.it/*",
    "https://*.instagram.com/*",
    "https://*.cdninstagram.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content/index.ts"]
    },
    {
      "matches": ["https://www.reddit.com/*"],
      "js": ["src/content-reddit/index.ts"]
    },
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["src/content-instagram/index.ts"]
    }
  ],
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon-16.png",
      "32": "public/icons/icon-32.png",
      "48": "public/icons/icon-48.png",
      "128": "public/icons/icon-128.png"
    }
  }
}
